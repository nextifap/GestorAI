// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

// MUDANÇA 1: Altera o provider para "postgresql"
// MUDANÇA 2: Adiciona a directUrl para o Prisma Migrate funcionar no Supabase
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") 
}

model User {
  id              String         @id @default(uuid())
  email           String         @unique
  senha           String
  nomeCompleto    String
  telegramId      String?        @unique @map("telegram_id")

  tasks           Task[]
  conversations   Conversation[]
  scheduleSlots   ManagerScheduleSlot[]
  managedAppointmentRequests AppointmentRequest[] @relation("ManagedAppointments")
  requestedAppointmentRequests AppointmentRequest[] @relation("RequestedAppointments")
}

model Task {
  id            String    @id @default(uuid())
  title         String
  isCompleted   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  userId        String
  user          User      @relation(fields: [userId], references: [id])
}

model Conversation {
  id            String        @id @default(uuid())
  summary       String
  createdAt     DateTime      @default(now())
  status        String        @default("active")
  channel       String        @default("web")
  handlingMode  String        @default("Automatizado")
  handoverAt    DateTime?
  handoverNote  String?
  triageScore   Float?
  triageReason  String?
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  messages      ChatMessage[]
  appointmentRequests AppointmentRequest[]

  @@index([status, createdAt])
  @@index([channel, createdAt])
}

model ManagerScheduleSlot {
  id            String   @id @default(uuid())
  date          DateTime
  hour          Int
  isAvailable   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  managerId     String
  manager       User     @relation(fields: [managerId], references: [id])
  appointmentRequests AppointmentRequest[]

  @@unique([managerId, date, hour])
  @@index([date, hour])
}

model AppointmentRequest {
  id             String   @id @default(uuid())
  requestedDate  DateTime
  requestedHour  Int
  status         String   @default("pending")
  justification  String?
  channel        String   @default("web")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  managerId      String
  manager        User     @relation("ManagedAppointments", fields: [managerId], references: [id])
  requesterId    String
  requester      User     @relation("RequestedAppointments", fields: [requesterId], references: [id])
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  managerSlotId  String?
  managerSlot    ManagerScheduleSlot? @relation(fields: [managerSlotId], references: [id])

  @@index([status, createdAt])
  @@index([requestedDate, requestedHour])
  @@index([managerId, status, createdAt])
}

model ChatMessage {
  id             String       @id @default(uuid())
  text           String
  sender         String
  createdAt      DateTime     @default(now())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

model SystemLog {
  id        String   @id @default(uuid())
  level     String
  source    String
  message   String
  context   Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([level])
}